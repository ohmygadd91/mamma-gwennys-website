---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us — Mamma Gwenny's"
  description="Get in touch with Mamma Gwenny's. We'd love to hear from you — whether it's a question about our seasonings, a wholesale enquiry, or just to say hello."
>
  <!-- Hero -->
  <section class="contact-hero" style="padding-top: 9rem;">
    <div class="contact-hero__pattern"></div>
    <div class="container contact-hero__inner">
      <h1>Contact Us</h1>
      <p class="contact-hero__subtitle">We'd love to hear from you</p>
    </div>
  </section>

  <section class="contact section">
    <div class="container contact__inner">
      <!-- Form -->
      <div class="contact__form-col">
        <h2>Send Us a Message</h2>
        <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p class="visually-hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="name" class="contact-form__label">Name</label>
              <input type="text" id="name" name="name" required class="contact-form__input" placeholder="Your name" />
            </div>
            <div class="contact-form__field">
              <label for="email" class="contact-form__label">Email</label>
              <input type="email" id="email" name="email" required class="contact-form__input" placeholder="your@email.com" />
            </div>
          </div>

          <div class="contact-form__field">
            <label for="subject" class="contact-form__label">Subject</label>
            <select id="subject" name="subject" required class="contact-form__input">
              <option value="">Select a subject</option>
              <option value="general">General Enquiry</option>
              <option value="order">Order Question</option>
              <option value="wholesale">Wholesale Enquiry</option>
              <option value="feedback">Feedback</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="contact-form__field">
            <label for="message" class="contact-form__label">Message</label>
            <textarea id="message" name="message" required rows="6" class="contact-form__input contact-form__textarea" placeholder="How can we help?"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
        </form>
      </div>

      <!-- Info sidebar -->
      <aside class="contact__info-col">
        <div class="contact-info">
          <div class="contact-info__block">
            <h3>Email Us</h3>
            <p><a href="mailto:hello@mammagwennys.com">hello@mammagwennys.com</a></p>
          </div>

          <div class="contact-info__block">
            <h3>Follow Us</h3>
            <div class="contact-info__social">
              <a href="#" aria-label="Instagram">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                </svg>
              </a>
              <a href="#" aria-label="Facebook">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
                </svg>
              </a>
              <a href="#" aria-label="TikTok">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52V6.8a4.84 4.84 0 01-1-.11z" />
                </svg>
              </a>
            </div>
          </div>

          <div class="contact-info__block">
            <h3>Response Time</h3>
            <p>We aim to respond to all enquiries within 24 hours during business days.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .contact-hero {
    background-color: var(--color-primary);
    color: var(--color-white);
    text-align: center;
    padding-block: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .contact-hero__pattern {
    position: absolute;
    inset: 0;
    background-image: url('/images/patterns/tropical-pattern.png');
    background-size: 400px;
    background-repeat: repeat;
    opacity: 0.08;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
  }

  .contact-hero h1 {
    color: var(--color-white);
    margin-bottom: var(--space-2);
  }

  .contact-hero__subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
  }

  /* Layout */
  .contact__inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-9);
    align-items: start;
  }

  /* Form */
  .contact__form-col h2 {
    color: var(--color-on-surface);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .contact-form__label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .contact-form__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--color-outline-variant);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-white);
    transition: border-color var(--transition-fast);
  }

  .contact-form__input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .contact-form__input::placeholder {
    color: var(--color-stone-300);
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 150px;
  }

  /* Info sidebar */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    box-shadow: var(--shadow-card);
    position: sticky;
    top: 140px;
  }

  .contact-info__block h3 {
    font-size: var(--text-base);
    color: var(--color-on-surface);
    margin-bottom: var(--space-2);
  }

  .contact-info__block p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .contact-info__block a {
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .contact-info__block a:hover {
    color: var(--color-primary-dark);
  }

  .contact-info__social {
    display: flex;
    gap: var(--space-3);
  }

  .contact-info__social a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .contact-info__social a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 1023px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .contact-info {
      position: static;
    }
  }

  @media (max-width: 639px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
