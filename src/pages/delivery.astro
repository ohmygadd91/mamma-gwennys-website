---
import BaseLayout from '../layouts/BaseLayout.astro';

const shippingZones = [
  {
    zone: 'United Kingdom',
    standard: '1–3 working days',
    cost: '£4.99',
    free: 'Free over £40',
  },
  {
    zone: 'Republic of Ireland',
    standard: '3–5 working days',
    cost: '£9.99',
    free: 'Free over £75',
  },
  {
    zone: 'Western Europe (FR, DE, BE, NL, LU)',
    standard: '3–5 working days',
    cost: '£12.99',
    free: 'Free over £75',
  },
  {
    zone: 'Southern Europe (ES, PT, IT, AT)',
    standard: '4–7 working days',
    cost: '£14.99',
    free: 'Free over £75',
  },
  {
    zone: 'Northern Europe (DK, SE, FI)',
    standard: '4–7 working days',
    cost: '£15.99',
    free: 'Free over £75',
  },
  {
    zone: 'Eastern Europe (PL, CZ, HU, RO)',
    standard: '5–8 working days',
    cost: '£14.99',
    free: 'Free over £75',
  },
];
---

<BaseLayout
  title="Delivery Information — Mamma Gwenny's"
  description="Delivery rates, shipping zones, and estimated delivery times for Mamma Gwenny's Caribbean seasonings across Europe."
>
  <!-- Hero -->
  <section class="delivery-hero" style="padding-top: 9rem;">
    <div class="delivery-hero__pattern"></div>
    <div class="container delivery-hero__inner">
      <h1>Delivery Information</h1>
      <p class="delivery-hero__subtitle">Shipping authentic Caribbean flavour across Europe</p>
    </div>
  </section>

  <section class="delivery section">
    <div class="container delivery__inner">
      <!-- Free delivery banner -->
      <div class="delivery-banner">
        <span class="delivery-banner__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" />
            <path d="M15 18H9" />
            <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14" />
            <circle cx="17" cy="18" r="2" />
            <circle cx="7" cy="18" r="2" />
          </svg>
        </span>
        <div>
          <strong>Free UK delivery on orders over £40</strong>
          <p>Free shipping to the rest of Europe on orders over £75</p>
        </div>
      </div>

      <!-- Shipping table -->
      <h2>Shipping Rates & Delivery Times</h2>
      <div class="delivery-table-wrapper">
        <table class="delivery-table">
          <thead>
            <tr>
              <th>Destination</th>
              <th>Estimated Delivery</th>
              <th>Shipping Cost</th>
              <th>Free Shipping</th>
            </tr>
          </thead>
          <tbody>
            {shippingZones.map((zone) => (
              <tr>
                <td data-label="Destination">{zone.zone}</td>
                <td data-label="Delivery Time">{zone.standard}</td>
                <td data-label="Cost">{zone.cost}</td>
                <td data-label="Free Shipping">{zone.free}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Additional info -->
      <div class="delivery-info-grid">
        <div class="delivery-info-card card">
          <h3>Order Processing</h3>
          <p>
            Orders are processed within 1–2 business days. You will receive a confirmation
            email with tracking information once your order has been dispatched.
          </p>
        </div>

        <div class="delivery-info-card card">
          <h3>Tracking Your Order</h3>
          <p>
            A tracking number will be emailed to you once your order ships. You can use this
            to follow your package's journey to your door.
          </p>
        </div>

        <div class="delivery-info-card card">
          <h3>Customs & Duties</h3>
          <p>
            All prices include UK VAT. Orders shipped to the EU and other international destinations
            may incur local import duties or VAT on arrival, which are the responsibility of the customer.
          </p>
        </div>

        <div class="delivery-info-card card">
          <h3>Damaged or Missing Items</h3>
          <p>
            If your order arrives damaged or items are missing, please contact us within 48 hours
            at <a href="mailto:hello@mammagwennys.com">hello@mammagwennys.com</a> with photos
            and your order number. We'll sort it out promptly.
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="delivery-cta text-center">
        <p>Have a question about delivery?</p>
        <a href="/contact" class="btn btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .delivery-hero {
    background-color: var(--color-primary);
    color: var(--color-white);
    text-align: center;
    padding-block: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .delivery-hero__pattern {
    position: absolute;
    inset: 0;
    background-image: url('/images/patterns/tropical-pattern.png');
    background-size: 400px;
    background-repeat: repeat;
    opacity: 0.08;
  }

  .delivery-hero__inner {
    position: relative;
    z-index: 1;
  }

  .delivery-hero h1 {
    color: var(--color-white);
    margin-bottom: var(--space-2);
  }

  .delivery-hero__subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
  }

  /* Content */
  .delivery__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .delivery__inner h2 {
    color: var(--color-on-surface);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
  }

  /* Free delivery banner */
  .delivery-banner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-cream));
    border: 2px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-8);
  }

  .delivery-banner__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 14%, transparent);
    color: var(--color-primary-dark);
    flex-shrink: 0;
  }

  .delivery-banner__icon svg {
    width: 36px;
    height: 36px;
  }

  .delivery-banner strong {
    font-size: var(--text-lg);
    color: var(--color-primary-dark);
    display: block;
    margin-bottom: var(--space-1);
  }

  .delivery-banner p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Table */
  .delivery-table-wrapper {
    overflow-x: auto;
    margin-bottom: var(--space-8);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .delivery-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-white);
    font-size: var(--text-sm);
  }

  .delivery-table th {
    background-color: var(--color-orange-dark);
    color: var(--color-white);
    font-family: var(--font-headline);
    text-transform: uppercase;
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    padding: var(--space-4);
    text-align: left;
    font-weight: 400;
  }

  .delivery-table td {
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-outline-variant);
    color: var(--color-text);
  }

  .delivery-table tbody tr:last-child td {
    border-bottom: none;
  }

  .delivery-table tbody tr:hover {
    background-color: var(--color-surface-low);
  }

  /* Info grid */
  .delivery-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .delivery-info-card {
    padding: var(--space-5);
  }

  .delivery-info-card h3 {
    font-size: var(--text-base);
    color: var(--color-on-surface);
    margin-bottom: var(--space-3);
  }

  .delivery-info-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .delivery-info-card a {
    color: var(--color-primary);
  }

  .delivery-info-card a:hover {
    color: var(--color-primary-dark);
  }

  /* CTA */
  .delivery-cta {
    padding-top: var(--space-7);
    border-top: 1px solid var(--color-outline-variant);
  }

  .delivery-cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  /* Mobile table */
  @media (max-width: 639px) {
    .delivery-table thead {
      display: none;
    }

    .delivery-table tr {
      display: block;
      padding: var(--space-4);
      border-bottom: 1px solid var(--color-outline-variant);
    }

    .delivery-table td {
      display: flex;
      justify-content: space-between;
      padding: var(--space-2) 0;
      border-bottom: none;
    }

    .delivery-table td::before {
      content: attr(data-label);
      font-weight: 600;
      color: var(--color-on-surface);
      margin-right: var(--space-3);
    }

    .delivery-info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
