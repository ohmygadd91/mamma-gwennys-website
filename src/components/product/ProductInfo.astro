---
interface Variant {
  id: string;
  label: string;
  price: number;
  weight: number;
}

interface Props {
  product: {
    id: string;
    slug: string;
    name: string;
    currency: string;
    description: string;
    shortDescription: string;
    image: string;
    color: string;
    variants: Variant[];
    ingredients: string;
    howToUse: string;
    nutritionalInfo: string;
  };
}

const { product } = Astro.props;
const defaultVariant = product.variants[0];
const formatter = new Intl.NumberFormat('en-GB', {
  style: 'currency',
  currency: product.currency,
});
const formattedDefaultPrice = formatter.format(defaultVariant.price);
---

<div class="product-info">
  <h1 class="product-info__name">{product.name}</h1>
  <p class="product-info__price" data-price-display>{formattedDefaultPrice}</p>
  <p class="product-info__description">{product.description}</p>

  <!-- Size picker -->
  <fieldset class="product-info__sizes">
    <legend class="product-info__sizes-label">Size</legend>
    <div class="product-info__sizes-options" role="radiogroup">
      {product.variants.map((v, i) => (
        <label class="product-info__size-chip">
          <input
            type="radio"
            name="variant"
            value={v.id}
            data-variant-id={v.id}
            data-variant-label={v.label}
            data-variant-price={v.price}
            data-variant-weight={v.weight}
            checked={i === 0}
          />
          <span>{v.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <!-- Quantity + Add to Cart -->
  <div class="product-info__actions">
    <div class="product-info__quantity">
      <label for="quantity" class="visually-hidden">Quantity</label>
      <button class="product-info__qty-btn" data-qty-decrease aria-label="Decrease quantity">−</button>
      <input
        type="number"
        id="quantity"
        name="quantity"
        value="1"
        min="1"
        max="10"
        class="product-info__qty-input"
        data-qty-input
      />
      <button class="product-info__qty-btn" data-qty-increase aria-label="Increase quantity">+</button>
    </div>

    <button
      class="snipcart-add-item btn btn-primary btn-lg product-info__cart-btn"
      data-add-to-cart
      data-item-id={defaultVariant.id}
      data-item-name={`${product.name} — ${defaultVariant.label}`}
      data-item-price={defaultVariant.price}
      data-item-url={`/products/${product.slug}`}
      data-item-image={product.image}
      data-item-description={product.shortDescription}
      data-item-weight={defaultVariant.weight}
      data-item-quantity="1"
      data-item-max-quantity="10"
      data-product-name={product.name}
    >
      Add to Cart
    </button>
  </div>

  <!-- Product details accordion -->
  <div class="product-info__details">
    <details class="product-info__accordion" open>
      <summary class="product-info__accordion-heading">Ingredients</summary>
      <div class="product-info__accordion-content">
        <p>{product.ingredients}</p>
      </div>
    </details>

    <details class="product-info__accordion">
      <summary class="product-info__accordion-heading">How to Use</summary>
      <div class="product-info__accordion-content">
        <p>{product.howToUse}</p>
      </div>
    </details>

    <details class="product-info__accordion">
      <summary class="product-info__accordion-heading">Nutritional Information</summary>
      <div class="product-info__accordion-content">
        <p>{product.nutritionalInfo}</p>
      </div>
    </details>
  </div>
</div>

<script>
  const addBtn = document.querySelector('[data-add-to-cart]') as HTMLElement | null;
  const priceDisplay = document.querySelector('[data-price-display]') as HTMLElement | null;
  const qtyInput = document.querySelector('[data-qty-input]') as HTMLInputElement | null;

  const formatter = new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' });

  function applyVariant(input: HTMLInputElement) {
    if (!addBtn) return;
    const id = input.dataset.variantId!;
    const label = input.dataset.variantLabel!;
    const price = Number(input.dataset.variantPrice);
    const weight = input.dataset.variantWeight!;
    const productName = addBtn.dataset.productName ?? '';

    addBtn.dataset.itemId = id;
    addBtn.dataset.itemName = `${productName} — ${label}`;
    addBtn.dataset.itemPrice = String(price);
    addBtn.dataset.itemWeight = weight;

    if (priceDisplay) priceDisplay.textContent = formatter.format(price);
  }

  document.querySelectorAll<HTMLInputElement>('input[name="variant"]').forEach((input) => {
    input.addEventListener('change', () => applyVariant(input));
  });

  document.querySelectorAll('[data-qty-decrease]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (qtyInput && Number(qtyInput.value) > 1) {
        qtyInput.value = String(Number(qtyInput.value) - 1);
        if (addBtn) addBtn.dataset.itemQuantity = qtyInput.value;
      }
    });
  });

  document.querySelectorAll('[data-qty-increase]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (qtyInput && Number(qtyInput.value) < 10) {
        qtyInput.value = String(Number(qtyInput.value) + 1);
        if (addBtn) addBtn.dataset.itemQuantity = qtyInput.value;
      }
    });
  });
</script>

<style>
  .product-info__name {
    color: var(--color-on-surface);
    margin-bottom: var(--space-3);
  }

  .product-info__price {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-on-surface);
    margin-bottom: var(--space-5);
  }

  .product-info__description {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  /* Size picker */
  .product-info__sizes {
    border: none;
    padding: 0;
    margin: 0 0 var(--space-6);
  }

  .product-info__sizes-label {
    font-family: var(--font-headline);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    padding: 0;
  }

  .product-info__sizes-options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .product-info__size-chip {
    cursor: pointer;
    user-select: none;
  }

  .product-info__size-chip input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .product-info__size-chip span {
    display: inline-block;
    padding: var(--space-3) var(--space-5);
    border: 2px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    font-family: var(--font-headline);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: border-color var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
  }

  .product-info__size-chip:hover span {
    border-color: var(--color-primary);
  }

  .product-info__size-chip input:checked + span {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .product-info__size-chip input:focus-visible + span {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Actions */
  .product-info__actions {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-7);
    flex-wrap: wrap;
  }

  .product-info__cart-btn {
    flex: 1;
    min-width: 200px;
  }

  /* Quantity stepper */
  .product-info__quantity {
    display: flex;
    align-items: center;
    border: 2px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .product-info__qty-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .product-info__qty-btn:hover {
    background-color: var(--color-gray-100);
  }

  .product-info__qty-input {
    width: 48px;
    height: 44px;
    text-align: center;
    border: none;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    background: none;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .product-info__qty-input::-webkit-inner-spin-button,
  .product-info__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Accordion */
  .product-info__details {
    border-top: 1px solid var(--color-gray-200);
  }

  .product-info__accordion {
    border-bottom: 1px solid var(--color-gray-200);
  }

  .product-info__accordion-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) 0;
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-style: normal;
    color: var(--color-on-surface);
    cursor: pointer;
    list-style: none;
    letter-spacing: 0.02em;
  }

  .product-info__accordion-heading::-webkit-details-marker {
    display: none;
  }

  .product-info__accordion-heading::after {
    content: '+';
    font-size: var(--text-xl);
    color: var(--color-primary);
    transition: transform var(--transition-fast);
  }

  [open] .product-info__accordion-heading::after {
    content: '−';
  }

  .product-info__accordion-content {
    padding-bottom: var(--space-4);
  }

  .product-info__accordion-content p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: var(--text-sm);
  }
</style>
