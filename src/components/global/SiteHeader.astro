---
const navLinks = [
  { label: 'Shop', href: '/shop' },
  { label: 'Our Story', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Delivery', href: '/delivery' },
  { label: 'Become a Stockist', href: '/trade' },
];
---

<header class="site-header">
  <nav class="site-header__inner">
    <button class="site-header__menu-btn" aria-label="Open menu" data-open-menu>
      <span class="material-symbols-outlined">menu</span>
    </button>

    <a href="/" class="site-header__logo">
      <img src="/images/logo.png" alt="Mamma Gwenny's" class="site-header__logo-img" />
    </a>

    <div class="site-header__nav">
      {navLinks.map((link) => (
        <a href={link.href} class="site-header__link">{link.label}</a>
      ))}
    </div>

    <div class="site-header__icons">
      <div class="site-header__search">
        <span class="material-symbols-outlined site-header__search-icon">search</span>
        <input type="text" placeholder="Search Seasonings..." class="site-header__search-input" />
      </div>
      <button class="site-header__icon" aria-label="Cart" data-open-cart>
        <span class="material-symbols-outlined">shopping_bag</span>
        <span class="site-header__cart-badge snipcart-items-count">0</span>
      </button>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    padding: 0 var(--space-6);
    max-width: 100%;
  }

  /* Logo */
  .site-header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-right: var(--space-7);
  }

  .site-header__logo-img {
    height: 120px;
    width: auto;
  }

  /* Nav */
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-header__link {
    font-family: var(--font-headline);
    font-weight: normal;
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-white);
    opacity: 0.85;
    transition: color var(--transition-fast), opacity var(--transition-fast);
    white-space: nowrap;
  }

  .site-header__link:hover {
    color: var(--color-primary-container);
    opacity: 1;
  }

  /* Icons — push to far right */
  .site-header__icons {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-left: auto;
  }

  .site-header__search {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.1);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    gap: var(--space-2);
  }

  .site-header__search-icon { color: rgba(255, 255, 255, 0.5); font-size: 20px; }

  .site-header__search-input {
    background: transparent; border: none; outline: none;
    font-size: var(--text-sm); font-weight: 500; width: 180px;
    color: var(--color-white);
  }

  .site-header__search-input::placeholder { color: rgba(255, 255, 255, 0.4); }

  .site-header__icon {
    color: var(--color-white);
    display: flex; align-items: center; position: relative;
    transition: transform var(--transition-fast);
  }

  .site-header__icon:active { transform: scale(0.95); }

  .site-header__cart-badge {
    position: absolute; top: -6px; right: -8px;
    background: var(--color-primary-container); color: var(--color-white);
    font-size: 10px; font-weight: 700; width: 16px; height: 16px;
    border-radius: var(--radius-full);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-label);
  }

  .site-header__menu-btn { display: none; color: var(--color-white); }

  @media (max-width: 1023px) {
    .site-header__nav { display: none; }
    .site-header__search { display: none; }
    .site-header__menu-btn { display: flex; align-items: center; }
    .site-header__logo-img { height: 80px; }
  }
</style>
