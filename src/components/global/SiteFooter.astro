---
const resourceLinks = [
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms of Service', href: '#' },
  { label: 'Shipping & Returns', href: '/delivery' },
];
const supportLinks = [
  { label: 'Contact Us', href: '/contact' },
  { label: 'FAQ', href: '/faq' },
];
---

<footer class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo">
        <img src="/images/logo.png" alt="Mamma Gwenny's" style="height: 120px; width: auto; margin-bottom: var(--space-4);" />
      </a>
      <p>Elevating the home cooking experience through artisanal Caribbean spice blends and traditional family recipes.</p>
      <div class="site-footer__social">
        <a href="#" aria-label="Instagram" class="site-footer__social-link">
          <span class="material-symbols-outlined">share</span>
        </a>
        <a href="#" aria-label="Facebook" class="site-footer__social-link">
          <span class="material-symbols-outlined">public</span>
        </a>
      </div>
    </div>

    <div class="site-footer__col">
      <h4>Resources</h4>
      <ul>
        {resourceLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h4>Support</h4>
      <ul>
        {supportLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <p class="site-footer__copy">&copy; {new Date().getFullYear()} Mamma Gwenny's. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #000;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-8);
    padding: var(--space-9) var(--space-8);
    max-width: 100%;
  }

  .site-footer__logo {
    display: block;
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: normal;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin-bottom: var(--space-5);
  }

  .site-footer__brand p {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    max-width: 320px;
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  .site-footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .site-footer__social-link {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .site-footer__social-link .material-symbols-outlined {
    font-size: 18px;
  }

  .site-footer__social-link:hover {
    background: var(--color-white);
    color: var(--color-primary);
  }

  .site-footer__col h4 {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-white);
    margin-bottom: var(--space-5);
  }

  .site-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .site-footer__col a {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--transition-fast);
  }

  .site-footer__col a:hover {
    color: var(--color-secondary-container);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .site-footer__copy {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    margin-top: var(--space-5);
  }

  @media (max-width: 1023px) {
    .site-footer__grid { grid-template-columns: 1fr; }
  }
</style>
