---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Shop All', href: '/shop' },
  { label: 'Our Story', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Delivery', href: '/delivery' },
];
---

<mobile-menu class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="mobile-menu__overlay" data-close-menu></div>
  <div class="mobile-menu__drawer">
    <div class="mobile-menu__header">
      <a href="/" class="mobile-menu__logo">
        <img src="/images/logo.png" alt="Mamma Gwenny's" style="height: 45px; width: auto;" />
      </a>
      <button class="mobile-menu__close" aria-label="Close menu" data-close-menu>
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-menu__link">{link.label}</a>
      ))}
    </nav>

    <div class="mobile-menu__footer">
      <div class="mobile-menu__social">
        <a href="#" aria-label="Instagram"><span class="material-symbols-outlined">photo_camera</span></a>
        <a href="#" aria-label="Facebook"><span class="material-symbols-outlined">public</span></a>
        <a href="#" aria-label="TikTok"><span class="material-symbols-outlined">play_circle</span></a>
      </div>
    </div>
  </div>
</mobile-menu>

<script>
  class MobileMenuElement extends HTMLElement {
    connectedCallback() {
      document.querySelectorAll('[data-open-menu]').forEach((btn) => {
        btn.addEventListener('click', () => this.open());
      });
      this.querySelectorAll('[data-close-menu]').forEach((el) => {
        el.addEventListener('click', () => this.close());
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.classList.contains('is-open')) this.close();
      });
    }

    open() {
      this.classList.add('is-open');
      this.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    close() {
      this.classList.remove('is-open');
      this.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }
  customElements.define('mobile-menu', MobileMenuElement);
</script>

<style>
  .mobile-menu { display: none; }

  @media (max-width: 1023px) {
    .mobile-menu {
      display: block;
      position: fixed;
      inset: 0;
      z-index: var(--z-drawer);
      pointer-events: none;
      visibility: hidden;
    }

    .mobile-menu.is-open {
      pointer-events: auto;
      visibility: visible;
    }

    .mobile-menu__overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      opacity: 0;
      transition: opacity var(--transition-base);
    }

    .mobile-menu.is-open .mobile-menu__overlay { opacity: 1; }

    .mobile-menu__drawer {
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      width: 320px;
      max-width: 85vw;
      background: var(--color-white);
      transform: translateX(-100%);
      transition: transform var(--transition-base);
      display: flex;
      flex-direction: column;
    }

    .mobile-menu.is-open .mobile-menu__drawer { transform: translateX(0); }

    .mobile-menu__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-5);
      border-bottom: 1px solid var(--color-stone-200);
    }

    .mobile-menu__logo {
      font-family: var(--font-headline);
      font-size: var(--text-xl);
      font-weight: 700;
      color: var(--color-on-surface);
    }

    .mobile-menu__close { color: var(--color-stone-600); }

    .mobile-menu__nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: var(--space-5);
    }

    .mobile-menu__link {
      font-family: var(--font-body);
      font-size: var(--text-lg);
      font-weight: 600;
      color: var(--color-on-surface);
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--color-stone-100);
      transition: color var(--transition-fast);
    }

    .mobile-menu__link:hover { color: var(--color-primary-container); }

    .mobile-menu__footer {
      padding: var(--space-5);
      border-top: 1px solid var(--color-stone-200);
    }

    .mobile-menu__social {
      display: flex;
      gap: var(--space-4);
    }

    .mobile-menu__social a {
      color: var(--color-stone-400);
      transition: color var(--transition-fast);
    }

    .mobile-menu__social a:hover { color: var(--color-primary-container); }
  }
</style>
